local function pingColor(p)
    if p <= 80 then return C.green
    elseif p <= 150 then return C.yellow
    else return C.red end
end

local function pingText(p)
    if p <= 80 then return "🟢 " .. p .. "ms"
    elseif p <= 150 then return "🟡 " .. p .. "ms"
    else return "🔴 " .. p .. "ms" end
end

local function buildRow(index, server)
    local isCurrent = server.id == game.JobId
    local playing = server.playing or 0
    local maxP = server.maxPlayers or 0
    local ping = server.ping or math.random(30, 220)
    local isFull = playing >= maxP
    local fillPct = maxP > 0 and (playing / maxP) or 0

    local row = Instance.new("Frame")
    row.Name = "ServerRow_" .. index
    row.Size = UDim2.new(1, 0, 0, ROW_H)
    row.BackgroundColor3 = isCurrent and C.greenDark or C.bgRow
    row.BorderSizePixel = 0
    row.Parent = scrollFrame
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

    local rowData = {
        frame = row,
        isCurrent = isCurrent,
        isFull = isFull,
        ping = ping,
        serverId = server.id
    }
    table.insert(themeableElements.rows, rowData)

    if isCurrent then
        local s = Instance.new("UIStroke")
        s.Name = "CurrentStroke"
        s.Color = C.green
        s.Thickness = 1
        s.Transparency = 0.4
        s.Parent = row
    end

    local bar = Instance.new("Frame")
    bar.Name = "StatusBar"
    bar.Size = UDim2.new(0, 2, 0.55, 0)
    bar.Position = UDim2.new(0, 0, 0.225, 0)
    bar.BackgroundColor3 = isCurrent and C.green or pingColor(ping)
    bar.BorderSizePixel = 0
    bar.Parent = row
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Name = "FillBar"
    fill.Size = UDim2.new(fillPct, 0, 1, 0)
    fill.BackgroundColor3 = isCurrent and C.currentFill or C.fillBg
    fill.BackgroundTransparency = 0.5
    fill.BorderSizePixel = 0
    fill.Parent = row
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 6)

    local function mk(name, txt, x, w, color, font, size)
        local l = Instance.new("TextLabel")
        l.Name = name
        l.Text = txt
        l.Size = UDim2.new(0, w, 1, 0)
        l.Position = UDim2.new(0, x, 0, 0)
        l.BackgroundTransparency = 1
        l.TextColor3 = color
        l.Font = font
        l.TextSize = size
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.Parent = row
        return l
    end

    mk("Index", string.format("%02d", index), 8, 24, C.textMuted, Enum.Font.GothamBold, 9)
    mk("Players", playing .. "/" .. maxP, 36, 72, isFull and C.red or C.text, Enum.Font.GothamBold, 13)
    mk("Ping", pingText(ping), 116, 90, pingColor(ping), Enum.Font.GothamBold, 10)
    mk("ServerId", string.sub(server.id, 1, 7) .. "..", 210, 85, C.textMuted, Enum.Font.Code, 9)

    local joinBtn = Instance.new("TextButton")
    joinBtn.Name = "JoinButton"
    joinBtn.Size = UDim2.new(0, 64, 0, ROW_H - 12)
    joinBtn.Position = UDim2.new(1, -68, 0.5, -(ROW_H - 12) / 2)
    joinBtn.BorderSizePixel = 0
    joinBtn.Font = Enum.Font.GothamBold
    joinBtn.TextSize = 10
    joinBtn.Parent = row
    Instance.new("UICorner", joinBtn).CornerRadius = UDim.new(0, 5)

    if isCurrent then
        joinBtn.Text = "✅ HERE"
        joinBtn.BackgroundColor3 = C.joinBtnHere
        joinBtn.TextColor3 = C.joinBtnHereText
        joinBtn.Active = false
    elseif isFull then
        joinBtn.Text = "FULL"
        joinBtn.BackgroundColor3 = C.joinBtnFull
        joinBtn.TextColor3 = C.joinBtnFullText
        joinBtn.Active = false
    else
        joinBtn.Text = "JOIN"
        joinBtn.BackgroundColor3 = C.accentDark
        joinBtn.TextColor3 = C.joinBtnText
        joinBtn.MouseButton1Click:Connect(function()
            joinBtn.Text = "⏳"
            joinBtn.BackgroundColor3 = isDarkMode and Color3.fromRGB(35, 35, 55) or Color3.fromRGB(226, 232, 240)
            statusLabel.Text = "🚀 Joining #" .. index
            statusLabel.TextColor3 = C.accent
            task.wait(0.3)
            TeleportService:TeleportToPlaceInstance(placeId, server.id, player)
        end)
        joinBtn.MouseEnter:Connect(function()
            TweenService:Create(joinBtn, TweenInfo.new(0.1), {BackgroundColor3 = C.joinBtnHover}):Play()
        end)
        joinBtn.MouseLeave:Connect(function()
            TweenService:Create(joinBtn, TweenInfo.new(0.1), {BackgroundColor3 = C.accentDark}):Play()
        end)
    end
end

function renderServers()
    themeableElements.rows = {}
    for _, c in ipairs(scrollFrame:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    
    local filtered = {}
    for _, s in ipairs(allServers) do
        local playing = s.playing or 0
        local maxP = math.max(s.maxPlayers or 1, 1)
        local ping = s.ping or 999
        
        if activeFilter == "All" then
            table.insert(filtered, s)
        elseif activeFilter == "Small" then
            if (playing / maxP) < 0.25 then table.insert(filtered, s) end
        elseif activeFilter == "Good Ping" then
            if ping <= 80 then table.insert(filtered, s) end
        end
    end
    
    if activeFilter == "Good Ping" then
        table.sort(filtered, function(a, b) return (a.ping or 999) < (b.ping or 999) end)
    elseif activeFilter == "Small" then
        table.sort(filtered, function(a, b) return (a.playing or 0) < (b.playing or 0) end)
    else
        table.sort(filtered, function(a, b)
            if a.id == game.JobId then return true end
            if b.id == game.JobId then return false end
            return (a.playing or 0) > (b.playing or 0)
        end)
    end
    
    if #filtered == 0 then
        local msg = Instance.new("TextLabel")
        msg.Name = "EmptyMessage"
        msg.Text = activeFilter == "Good Ping" and "⚡ No servers under 80ms"
            or activeFilter == "Small" and "🟢 No small servers found"
            or "🌐 No servers found"
        msg.Size = UDim2.new(1, 0, 0, 50)
        msg.BackgroundTransparency = 1
        msg.TextColor3 = C.textMuted
        msg.Font = Enum.Font.Gotham
        msg.TextSize = 11
        msg.Parent = scrollFrame
    end
    
    for i, s in ipairs(filtered) do buildRow(i, s) end
    serverCountLabel.Text = #filtered .. "/" .. #allServers
end

local function loadServers()
    themeableElements.rows = {}
    for _, c in ipairs(scrollFrame:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    allServers = {}
    statusLabel.Text = "⏳ Loading..."
    statusLabel.TextColor3 = C.yellow
    serverCountLabel.Text = ""
    refreshBtn.Text = "⏳ ..."
    refreshBtn.Active = false
    
    local seen = {}
    
    local function fetchPage(sort, maxPg)
        local cursor = ""
        local pages = 0
        repeat
            local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=" .. sort .. "&limit=100" .. (cursor ~= "" and "&cursor=" .. cursor or "")
            local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
            if not ok or not result or not result.data then break end
            for _, s in ipairs(result.data) do
                if not seen[s.id] then
                    seen[s.id] = true
                    table.insert(allServers, s)
                end
            end
            cursor = result.nextPageCursor or ""
            pages = pages + 1
            task.wait(0.1)
        until cursor == "" or pages >= maxPg
    end
    
    fetchPage("Desc", 3)
    fetchPage("Asc", 3)
    
    if not seen[game.JobId] then
        table.insert(allServers, 1, {
            id = game.JobId,
            playing = #Players:GetPlayers(),
            maxPlayers = Players.MaxPlayers,
            ping = 50
        })
    end
    
    statusLabel.Text = "✅ Loaded"
    statusLabel.TextColor3 = C.green
    refreshBtn.Text = "🔄 Refresh"
    refreshBtn.Active = true
    renderServers()
end

refreshBtn.MouseButton1Click:Connect(function() task.spawn(loadServers) end)

task.spawn(loadServers)
