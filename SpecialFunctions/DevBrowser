local function makeBtn(text, bg, tc, px, pw, parent, name)
    local b = Instance.new("TextButton")
    b.Name = name or "Button"
    b.Size = UDim2.new(0, pw, 0, 24)
    b.Position = UDim2.new(1, px, 0.5, -12)
    b.BackgroundColor3 = bg
    b.Text = text
    b.TextColor3 = tc
    b.Font = Enum.Font.GothamBold
    b.TextSize = 11
    b.BorderSizePixel = 0
    b.Parent = parent
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    
    b.MouseEnter:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), {BackgroundTransparency = 0.3}):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), {BackgroundTransparency = 0}):Play()
    end)
    
    table.insert(themeableElements.textButtons, {obj = b, name = name, bg = bg, text = tc})
    return b
end

