local function applyTheme()
    local theme = isDarkMode and Themes.Dark or Themes.Light
    C = theme
    
    frame.BackgroundColor3 = theme.bg
    titleBar.BackgroundColor3 = theme.titleBar
    titleFix.BackgroundColor3 = theme.titleBar
    tabBar.BackgroundColor3 = theme.topBarBg
    shine.BackgroundColor3 = theme.shine
    sep.BackgroundColor3 = theme.border
    divider.BackgroundColor3 = theme.border
    
    stroke.Color = theme.border
    tabStroke.Color = theme.border
    
    scrollFrame.ScrollBarImageColor3 = theme.scrollBar
    
    themeBtn.Text = isDarkMode and "🌙 Dark" or "☀️ Light"
    themeBtn.BackgroundColor3 = theme.tabInactive
    themeBtn.TextColor3 = theme.themeBtnText
    
    for _, item in ipairs(themeableElements.textLabels) do
        local lbl = item.obj
        if item.type == "status" then
            if statusLabel.Text:match("Ready") or statusLabel.Text:match("Loading") then
                lbl.TextColor3 = theme.textDim
            end
        elseif item.type == "accent" then
            lbl.TextColor3 = theme.accent
        end
    end
    
    for _, item in ipairs(themeableElements.textButtons) do
        local btn = item.obj
        if item.name == "Close" then
            btn.BackgroundColor3 = theme.closeBtn
        elseif item.name == "Minimize" then
            btn.BackgroundColor3 = theme.minBtn
        elseif item.name == "Refresh" then
            btn.BackgroundColor3 = theme.accentDark
        end
    end
    
    for _, t in ipairs(themeableElements.tabs) do
        if t.name == activeFilter then
            t.btn.BackgroundColor3 = theme.tabActive
            t.lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            t.btn.BackgroundColor3 = theme.tabInactive
            t.lbl.TextColor3 = theme.textMuted
        end
    end
    
    for _, rowData in ipairs(themeableElements.rows) do
        local row = rowData.frame
        local isCurrent = rowData.isCurrent
        local isFull = rowData.isFull
        
        row.BackgroundColor3 = isCurrent and theme.greenDark or theme.bgRow
        
        local fill = row:FindFirstChild("FillBar")
        if fill then
            fill.BackgroundColor3 = isCurrent and theme.currentFill or theme.fillBg
        end
        
        local bar = row:FindFirstChild("StatusBar")
        if bar then
            if isCurrent then
                bar.BackgroundColor3 = theme.green
            else
                local ping = rowData.ping or 999
                if ping <= 80 then
                    bar.BackgroundColor3 = theme.green
                elseif ping <= 150 then
                    bar.BackgroundColor3 = theme.yellow
                else
                    bar.BackgroundColor3 = theme.red
                end
            end
        end
        
        for _, child in ipairs(row:GetChildren()) do
            if child:IsA("TextLabel") then
                local text = child.Text
                if text:match("^%d%d$") then
                    child.TextColor3 = theme.textMuted
                elseif text:match("/") then
                    child.TextColor3 = isFull and theme.red or theme.text
                elseif text:match("ms") then
                    local ping = tonumber(text:match("%d+")) or 999
                    if ping <= 80 then
                        child.TextColor3 = theme.green
                    elseif ping <= 150 then
                        child.TextColor3 = theme.yellow
                    else
                        child.TextColor3 = theme.red
                    end
                elseif text:match("%.%.") then
                    child.TextColor3 = theme.textMuted
                end
            elseif child:IsA("TextButton") then
                if isCurrent then
                    child.BackgroundColor3 = theme.joinBtnHere
                    child.TextColor3 = theme.joinBtnHereText
                elseif isFull then
                    child.BackgroundColor3 = theme.joinBtnFull
                    child.TextColor3 = theme.joinBtnFullText
                else
                    child.BackgroundColor3 = theme.accentDark
                    child.TextColor3 = theme.joinBtnText
                end
            elseif child:IsA("UIStroke") then
                child.Color = theme.green
            end
        end
    end
end

